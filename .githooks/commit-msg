#!/usr/bin/env bash
set -euo pipefail

message_file="${1:?commit message file is required}"
first_line="$(head -n 1 "$message_file")"

if [[ ! "$first_line" =~ ^(feat|fix|docs|chore|refactor|test|ops|data|style|perf|build|ci)(\([a-z0-9._-]+\))?:\ .+ ]]; then
  echo "Commit message must use Conventional Commits, for example: feat: add delivery preset" >&2
  exit 1
fi
